# -----------------------------------------------------------------------------
# Custom project repository safety rules
# The upstream Odoo core is cloned separately to /opt/odoo/odoo in production.
# -----------------------------------------------------------------------------

# Python virtual environments
/.venv/
/venv/
/env/

# Python and test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Logs and runtime files
*.log
/logs/
/sessions/
**/sessions/

# Local and production secrets/configuration
.env
.env.*
!deployment/.env.example
/odoo.conf
/odoo.conf.*
!deployment/odoo.conf.example
*.pem
*.key
*.p12
*.pfx

# rclone/OAuth credentials and deployment secret material
**/rclone.conf
**/*rclone*.conf
**/.config/rclone/
**/client_secret*.json
**/credentials*.json
**/oauth*.json
*.token
/deployment/secrets/


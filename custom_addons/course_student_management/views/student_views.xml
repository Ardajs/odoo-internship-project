<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_student_tree" model="ir.ui.view">
        <field name="name">student.student_management.tree</field>
        <field name="model">student.student_management</field>
        <field name="arch" type="xml">
            <tree string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
            </tree>
        </field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.student_management.form</field>
        <field name="model">student.student_management</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                    </group>

                    <notebook>
                        <page string="Sessions">
                            <field name="session_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="course_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student.student_management.search</field>
        <field name="model">student.student_management</field>
        <field name="arch" type="xml">
            <search string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
            </search>
        </field>
    </record>

</odoo>
# Copy this file to /etc/odoo/deployment.env on the VPS.
# Set owner root:odoo and mode 0640. Never commit the real file.

DOMAIN_NAME=DOMAIN_NAME
SERVER_IP=SERVER_IP
GITHUB_REPO_URL=GITHUB_REPO_URL
CUSTOM_BRANCH=main

DATABASE_NAME=DATABASE_NAME
PRODUCTION_DATABASE=DATABASE_NAME
DB_ROLE=odoo

ODOO_VERSION=19.0
ODOO_COMMIT=CHANGE_ME_TO_TESTED_COMMIT_SHA
ODOO_CORE_REPO=https://github.com/odoo/odoo.git
ODOO_CORE_DIR=/opt/odoo/odoo
PROJECT_DIR=/opt/odoo/project
VENV_DIR=/opt/odoo/venv
ODOO_CONFIG=/etc/odoo/odoo.conf
ODOO_SERVICE=odoo.service

FILESTORE_ROOT=/var/lib/odoo/filestore
LOG_DIR=/var/log/odoo
BACKUP_ROOT=/var/backups/odoo
RETENTION_DAYS=7
CONSISTENCY_MODE=stop

CUSTOM_MODULES=ardaapp,internship_logbook,sales_app,course_student_management

# Do not put Odoo master, PostgreSQL or SMTP passwords in this file.
# PostgreSQL uses a local Unix socket with matching OS/database role "odoo".

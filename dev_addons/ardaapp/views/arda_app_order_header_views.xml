<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>

        <record id="order_header_action" model="ir.actions.act_window">
            <field name="name">Order</field>
            <field name="res_model">order.header</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first order.
                </p>
            </field>
        </record>

        <record id="order_header_view_tree" model="ir.ui.view">
            <field name="name">order.header.view.tree</field>
            <field name="model">order.header</field>
            <field name="arch" type="xml">
                <list string="Orders">
                    <field name="name" />
                    <field name="customer_id" />
                    <field name="order_date" />
                </list>
            </field>
        </record>

        <record id="order_header_view_form" model="ir.ui.view">
            <field name="name">order.header.view.form</field>
            <field name="model">order.header</field>
            <field name="arch" type="xml">
                <form string="Order">
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="customer_id" />
                            <field name="order_date" />
                        </group>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

    </data>
</odoo>
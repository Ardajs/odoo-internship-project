<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="mail_template_self_registration_verify" model="mail.template">
        <field name="name">Internship Portal: Verify Email</field>
        <field name="model_id" ref="model_internship_self_registration"/>
        <field name="subject">Verify your Internship Logbook account</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
            <div>
                <p>Hello <t t-out="object.name"/>,</p>
                <p>
                    Confirm your email address to create your Internship
                    Logbook portal account.
                </p>
                <p>
                    <a t-att-href="ctx.get('verification_url')"
                       style="background:#714B67;color:#fff;padding:10px 18px;
                              text-decoration:none;border-radius:4px;">
                        Verify Email
                    </a>
                </p>
                <p>This link expires in 24 hours and can be used only once.</p>
                <p>If you did not request this account, ignore this message.</p>
            </div>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- ===================================================== -->
    <!-- SECURITY GROUPS                                       -->
    <!-- ===================================================== -->

    <record id="group_internship_intern" model="res.groups">
        <field name="name">Internship / Intern</field>
    </record>

    <record id="group_internship_supervisor" model="res.groups">
        <field name="name">Internship / Supervisor</field>
    </record>

    <record id="group_internship_manager" model="res.groups">
        <field name="name">Internship / Manager</field>
    </record>


    <!-- ===================================================== -->
    <!-- INTERN RECORD RULES                                    -->
    <!-- ===================================================== -->

    <record id="rule_internship_student_intern" model="ir.rule">
        <field name="name">Intern: Own Student Record</field>
        <field name="model_id" ref="model_internship_student"/>
        <field
            name="groups"
            eval="[Command.link(ref('group_internship_intern'))]"/>
        <field name="domain_force">
            [('user_id', '=', user.id)]
        </field>
    </record>

    <record id="rule_internship_program_intern" model="ir.rule">
        <field name="name">Intern: Own Internship Programs</field>
        <field name="model_id" ref="model_internship_program"/>
        <field
            name="groups"
            eval="[Command.link(ref('group_internship_intern'))]"/>
        <field name="domain_force">
            [('student_id.user_id', '=', user.id)]
        </field>
    </record>

    <record id="rule_internship_daily_entry_intern" model="ir.rule">
        <field name="name">Intern: Own Daily Entries</field>
        <field name="model_id" ref="model_internship_daily_entry"/>
        <field
            name="groups"
            eval="[Command.link(ref('group_internship_intern'))]"/>
        <field name="domain_force">
            [('student_id.user_id', '=', user.id)]
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- SUPERVISOR RECORD RULES                                -->
    <!-- ===================================================== -->

    <record id="rule_internship_student_supervisor" model="ir.rule">
        <field name="name">Supervisor: Assigned Students</field>
        <field name="model_id" ref="model_internship_student"/>
        <field
            name="groups"
            eval="[Command.link(ref('group_internship_supervisor'))]"/>
        <field name="domain_force">
            [('program_ids.supervisor_id', '=', user.id)]
        </field>
    </record>

    <record id="rule_internship_program_supervisor" model="ir.rule">
        <field name="name">Supervisor: Assigned Internship Programs</field>
        <field name="model_id" ref="model_internship_program"/>
        <field
            name="groups"
            eval="[Command.link(ref('group_internship_supervisor'))]"/>
        <field name="domain_force">
            [('supervisor_id', '=', user.id)]
        </field>
    </record>

    <record id="rule_internship_daily_entry_supervisor" model="ir.rule">
        <field name="name">Supervisor: Assigned Daily Entries</field>
        <field name="model_id" ref="model_internship_daily_entry"/>
        <field
            name="groups"
            eval="[Command.link(ref('group_internship_supervisor'))]"/>
        <field name="domain_force">
            [('supervisor_id', '=', user.id)]
        </field>
    </record>

</odoo>
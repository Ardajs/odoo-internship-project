<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- Student List View -->
    <record id="view_internship_student_list" model="ir.ui.view">
        <field name="name">internship.student.list</field>
        <field name="model">internship.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="student_number"/>
                <field name="university"/>
                <field name="department"/>
                <field name="class_year"/>
                <field name="email"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>


    <!-- Student Form View -->
    <record id="view_internship_student_form" model="ir.ui.view">
        <field name="name">internship.student.form</field>
        <field name="model">internship.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>

                    <div class="oe_button_box" name="button_box">

                        <button
                            name="action_view_programs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-briefcase">

                            <field
                                name="program_count"
                                widget="statinfo"
                                string="Programs"/>

                        </button>

                    </div>

                    <group>
                        <group string="Student Information">
                            <field name="name"/>
                            <field name="student_number"/>
                            <field name="user_id"/>
                            <field name="class_year"/>
                            <field name="active"/>
                        </group>

                        <group string="Contact Information">
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                    </group>

                    <group string="Education Information">
                        <group>
                            <field name="university"/>
                            <field name="faculty"/>
                        </group>

                        <group>
                            <field name="department"/>
                        </group>
                    </group>

                    <group string="Additional Information">
                        <field
                            name="notes"
                            placeholder="Enter additional notes about the student..."/>
                    </group>

                    <notebook>
                        <page string="Internship Programs">
                            <field
                                name="program_ids"
                                context="{'default_student_id': id}">

                                <list>
                                    <field name="name"/>
                                    <field name="company_name"/>
                                    <field name="department"/>
                                    <field name="supervisor_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="duration_days"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    <!-- Student Search View -->
    <record id="view_internship_student_search" model="ir.ui.view">
        <field name="name">internship.student.search</field>
        <field name="model">internship.student</field>
        <field name="arch" type="xml">
            <search string="Search Students">

                <field name="name"/>
                <field name="student_number"/>
                <field name="university"/>
                <field name="department"/>

                <separator/>

                <filter
                    name="active_students"
                    string="Active Students"
                    domain="[('active', '=', True)]"/>

                <filter
                    name="archived_students"
                    string="Archived Students"
                    domain="[('active', '=', False)]"/>

                <separator/>

                <filter
                    name="group_by_university"
                    string="University"
                    context="{'group_by': 'university'}"/>

                <filter
                    name="group_by_department"
                    string="Department"
                    context="{'group_by': 'department'}"/>

                <filter
                    name="group_by_class_year"
                    string="Class Year"
                    context="{'group_by': 'class_year'}"/>

            </search>
        </field>
    </record>


    <!-- Student Window Action -->
    <record id="action_internship_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">internship.student</field>
        <field name="view_mode">list,form</field>
        <field
            name="search_view_id"
            ref="view_internship_student_search"/>
        <field name="context">
            {'search_default_active_students': 1}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first internship student
            </p>
            <p>
                Manage students who participate in internship programs.
            </p>
        </field>
    </record>

</odoo>
